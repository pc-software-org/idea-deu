# Enable inlay-based IME in thin client
editor.input.method.inlay=true
# Enable "Current File" item in run widget
run.current.file.item.in.run.configurations.combobox=true
# Disable Preview in Search Everywhere
search.everywhere.preview=false
# Disable preferred tree width cache
ide.tree.experimental.preferred.width=false
# Enable the new Search Everywhere in remdev mode (frontend side, excl. Rider)
search.everywhere.new.enabled=true
# Enable Editors' tab loading icon
editor.loading.spinner.enabled=true
# IJPL-192833: disabled due to lack of serialization for frontend hints
cache.inlay.hints.on.disk=false
