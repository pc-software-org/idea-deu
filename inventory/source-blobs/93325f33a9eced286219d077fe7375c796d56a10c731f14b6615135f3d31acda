<p>Reports incorrect repository method parameter types.</p>
<!-- tooltip end -->
<p><b>Example:</b></p>
<pre><code lang="java">
  public class Person {
    private int id;
    @Column
    private String lastname;

    @Column
    private int age;
  }

  public interface CustomerRepository extends Repository&lt;Person, Integer&gt; {
    List&lt;Person&gt; <strong>findByAddress</strong>(int lastname);  // 'String' type expected
    List&lt;Person&gt; <strong>deleteByAge</strong>(String str);   // 'int' type expected
  }
</code></pre>
</body>
