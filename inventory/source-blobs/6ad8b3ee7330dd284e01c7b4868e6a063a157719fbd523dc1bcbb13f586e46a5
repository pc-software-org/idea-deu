<p>Reports incorrect Micronaut Data repository method parameter types.</p>
<!-- tooltip end -->
<p><b>Example:</b></p>
<pre><code lang="java">
  public class Person {
    private int id;
    private String lastname;
    private Address address;
  }

  public class Address {
    private int zipCode;
  }

  public interface CustomerRepository extends CrudRepository&lt;Person, Integer&gt; {
    List&lt;Person&gt; <strong>findByAddress</strong>(String lastname);  // 'Address' type expected
    List&lt;Person&gt; <strong>findByAddressZipCode</strong>(String str);   // 'int' type expected
  }
</code></pre>
</body>
