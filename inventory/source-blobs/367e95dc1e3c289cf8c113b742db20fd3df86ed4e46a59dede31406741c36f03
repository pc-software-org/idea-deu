<p>
  Reports Spring Data CRUD repository methods for which the
  <a href="https://docs.spring.io/spring-data/jpa/docs/current/reference/html/#repositories.query-methods.query-creation">Spring Data Query</a>
  builder cannot generate the corresponding query.
</p>

<p><b>Example:</b></p>
<pre><code lang="java">
interface PersonRepository extends Repository&lt;Person, Long&gt; {
  List&lt;Person&gt; findByEmailAddressAndLastname(EmailAddress emailAddress, String lastname);
  List&lt;Person&gt; findByEmail<strong>Unknown</strong>AndLastname(EmailAddress emailAddress, String lastname); // Cannot resolve property 'Unknown'
  List&lt;Person&gt; <strong>findByAndLastname</strong>(EmailAddress emailAddress, String lastname); // Missing property name

  List&lt;Person&gt; findDistinctPeopleByLastnameOrFirstname(String lastname, String firstname);
  List&lt;Person&gt; findPeopleDistinctBy<strong>Unknown</strong>OrFirstname(String lastname, String firstname); // Cannot resolve property 'Unknown'

  List&lt;Person&gt; findByLastnameOrderByFirstnameAsc(String lastname);
  List&lt;Person&gt; findByLastnameOrderBy<strong>Unknown</strong>Desc(String lastname);  // Cannot resolve property 'Unknown'
}
</code></pre>
</body>
