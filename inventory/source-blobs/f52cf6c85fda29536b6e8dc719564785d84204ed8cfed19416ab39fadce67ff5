<p>
  Reports Jakarta Dat repository methods for which the builder cannot generate the corresponding query.
</p>

<p><b>Example:</b></p>
<pre><code lang="java">
interface PersonRepository extends Repository&lt;Person, Long&gt; {
  List&lt;Person&gt; findByEmailAndLastname(String email, String lastname);
  List&lt;Person&gt; findByUnknownAndLastname(EmailAddress emailAddress, String lastname); // Cannot resolve property 'Unknown'
  List&lt;Person&gt; findByAndLastname(String email, String lastname); // Missing property name

  List&lt;Person&gt; findByLastnameOrderByFirstnameAsc(String lastname);
  List&lt;Person&gt; findByLastnameOrderByUnknownDesc(String lastname);  // Cannot resolve property 'Unknown'
}
</code></pre>
</body>
