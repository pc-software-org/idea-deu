Reports an unreachable <code>case</code> branch of a <code>switch</code> statement. <p>Example:</p>
<pre><code>
/**
 * @param {('foo' | 'bar')} p
 */
function foo(p) {
    switch (p) {
        case 'foo': break;
        case 'bar': break;
        case 'baz': break; // unreachable
    }
}
</code></pre>
