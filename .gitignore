# IntelliJ distributions are immutable build inputs, not repository content.
/idea-*.zip

# Generated and local build artifacts.
/generated/
/dist/
/.gradle/
/build/
/.worktrees/

# Local Python artifacts.
__pycache__/
*.py[cod]
/.venv/
/.batch.lock

# Subagent-driven-development scratch ledger.
/.superpowers/

# Local plugin-signing material: the private key stays out of git; the public
# certificate is published so users can verify the signature.
/signing/*
!/signing/chain.crt
