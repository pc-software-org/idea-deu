{
  "container_exclusions": [
    {
      "glob": "**/lib/jna-platform.jar",
      "reason": "third_party_container"
    },
    {
      "glob": "**/lib/jna.jar",
      "reason": "third_party_container"
    },
    {
      "glob": "**/lib/jsr305.jar",
      "reason": "third_party_container"
    }
  ],
  "resource_patterns": [
    "*.properties",
    "inspectionDescriptions/**/*.html",
    "intentionDescriptions/**/*.html",
    "fileTemplates/**/*.html",
    "postfixTemplates/**/*.xml",
    "tips/**/*.html"
  ],
  "localization_directories": [
    "i18n",
    "l10n",
    "localization",
    "localized"
  ],
  "limits": {
    "max_containers": 20000,
    "max_members": 2000000,
    "max_nested_jar_bytes": 536870912,
    "max_outer_members": 100000,
    "max_resource_bytes": 16777216,
    "max_total_nested_jar_bytes": 8589934592,
    "max_total_resource_bytes": 4294967296,
    "spool_memory_bytes": 67108864
  }
}
